<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="TestSuite">

    <groups>
        <run>
            <include name="SubmitOrder"/>
        </run>
    </groups>
    
    <listeners>
        <listener class-name="E2E.TestComponents.Listener"/>
    </listeners>

   <test name="Regression" parallel="classes" thread-count="5">
       <classes>
           <class name="E2E.tests.ErrorCasesTest"/>
           <class name = "E2E.tests.SubmitOrderTest"/>
       </classes>
   </test>
</suite>